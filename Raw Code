    <style>
        /* Variables de color y efectos de tu CV original */
        :root {
            --primary-color: #2c3e50;
            --secondary-color: #3498db;
            --accent-color: #f39c12;
            --icon-color: #F1C40F; /* CAMBIADO: Amarillo suave para íconos */
            --light-color: #ecf0f1;
            --dark-color: #2c3e50;
            --text-color: #333;
            --border-radius: 8px;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            overflow: hidden;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: var(--text-color);
            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .marco {
            width: 90%;
            max-width: 1400px;
            height: 90vh;
            min-height: 600px;
            border: 2px solid var(--primary-color);
            border-radius: 0;
            background-color: white;
            box-shadow: 0 0 50px rgba(0, 0, 0, 0.1);
            position: relative;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
        }

        .marco-interior {
            display: flex;
            width: 100%;
            height: 100%;
            position: relative;
            flex: 1;
            overflow: hidden;
        }

        .izquierda {
            width: 35%;
            border-right: 2px solid var(--primary-color);
            display: flex;
            flex-direction: column;
            background: linear-gradient(180deg, var(--primary-color) 0%, #1a252f 100%);
            color: white;
            position: relative;
            overflow: hidden;
        }

        .izquierda-scrollable {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            height: 100%;
        }

        .derecha {
            width: 65%;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        /* SCROLLBAR PARA IZQUIERDA */
        .izquierda-scrollable::-webkit-scrollbar {
            width: 8px;
        }

        .izquierda-scrollable::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 4px;
        }

        .izquierda-scrollable::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, var(--secondary-color) 0%, var(--accent-color) 100%);
            border-radius: 4px;
        }

        /* BOTÓN DONA/MENÚ HAMBURGUESA - DENTRO DE LA FOTO */
        .dona-menu {
            display: none;
            position: absolute;
            top: 15px;
            right: 15px;
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary-color) 0%, #1a252f 100%);
            border-radius: 50%;
            border: 2px solid var(--accent-color);
            z-index: 1000;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
            transition: var(--transition);
            justify-content: center;
            align-items: center;
            flex-direction: column;
            gap: 4px;
            padding: 8px;
        }

        .foto-contenedor:hover .dona-menu {
            border-color: white;
            background: linear-gradient(135deg, var(--secondary-color) 0%, #2980b9 100%);
        }

        .dona-menu:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
            border-color: var(--accent-color);
        }

        .dona-line {
            width: 20px;
            height: 2px;
            background-color: var(--icon-color);
            border-radius: 2px;
            transition: var(--transition);
        }

        .dona-menu.active .dona-line:nth-child(1) {
            transform: rotate(45deg) translate(5px, 5px);
        }

        .dona-menu.active .dona-line:nth-child(2) {
            opacity: 0;
        }

        .dona-menu.active .dona-line:nth-child(3) {
            transform: rotate(-45deg) translate(5px, -5px);
        }

